# =============================================================
# Orbi — Environment Variables
# Copy to .env and fill in your values
# =============================================================

# Server
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:5173

# Postgres (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/orbi?sslmode=require
# Set to "true" to auto-apply pending Drizzle migrations on boot
RUN_MIGRATIONS_ON_BOOT=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (for Calendar + Gmail integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Stripe (CAD billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_AGENT=price_...   # $9.99 CAD/month
STRIPE_PRICE_FULL=price_...    # $24.99 CAD/month
