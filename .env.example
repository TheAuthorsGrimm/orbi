# =============================================================
# Orbi v1 — Environment Variables
# Copy to .env.local for local dev. In Vercel, set these under
# Project Settings → Environment Variables.
# =============================================================

# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/orbi?sslmode=require
AUTH_SECRET=run "openssl rand -base64 32" and paste the result
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (required for billing/upgrades) ────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_AGENT=price_...
STRIPE_PRICE_FULL=price_...

# ── Optional ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
