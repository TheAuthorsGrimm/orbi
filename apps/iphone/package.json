{
  "name": "@orbi/iphone",
  "version": "1.0.0",
  "description": "Orbi ADHD Companion - iOS App",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:device": "react-native run-ios --device",
    "build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "build:ios": "cd ios && xcodebuild -workspace Orbi.xcworkspace -scheme Orbi -configuration Release -derivedDataPath build",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.1",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "react": "18.3.1",
    "react-native": "^0.74.5",
    "react-native-gesture-handler": "^2.15.0",
    "react-native-reanimated": "^3.10.1",
    "react-native-screens": "^3.30.1",
    "react-native-safe-area-context": "^4.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.5",
    "@babel/preset-typescript": "^7.24.1",
    "@react-native/babel-preset": "^0.74.85",
    "@react-native/eslint-config": "^0.74.85",
    "@react-native/typescript-config": "^0.74.85",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.12",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
